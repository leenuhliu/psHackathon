/**
 * animation-routes.js
 *
 * Add these two routes to your server.js (or paste them in).
 *
 * POST /api/generate-animation   → starts Veo job, returns { job_id }
 * GET  /api/animation-progress/:job_id → poll for status / video_url
 *
 * The ViewingScreen calls these automatically on mount.
 */

import { GoogleGenAI } from '@google/genai';
import { randomUUID } from 'crypto';
import fs from 'fs';
import path from 'path';

const ai = new GoogleGenAI({ apiKey: process.env.GEMINI_API_KEY });
const VIDEOS_DIR = path.join(process.cwd(), 'generated-videos');
fs.mkdirSync(VIDEOS_DIR, { recursive: true });

// In-memory job store — same pattern as server.js
// If you already have a `jobs` object in server.js, reuse that instead.
const animationJobs = {};

// ── Helper: build a Veo prompt from the drawings + story details ──────────
async function buildVeoPrompt(drawings, storyDetails) {
  // Ask Gemini to describe the drawing(s) and compose an animation prompt
  const parts = [];

  // Include up to 3 drawings as images
  for (const dataUrl of drawings.slice(0, 3)) {
    const base64 = dataUrl.replace(/^data:image\/\w+;base64,/, '');
    parts.push({ inlineData: { mimeType: 'image/png', data: base64 } });
  }

  const contextText = storyDetails?.length
    ? `Story details: ${storyDetails.join(', ')}.`
    : '';

  parts.push({
    text: `${contextText}
These are children's drawings. Write a vivid 2-3 sentence animation prompt for Veo that:
- Brings these characters/scenes to life as a short animated clip
- Mentions "hand-drawn doodle animation style, colourful, child-friendly, gentle movement"
- Describes what happens in the scene

Reply with ONLY the prompt text, nothing else.`,
  });

  const res = await ai.models.generateContent({
    model: 'gemini-2.0-flash',
    contents: [{ role: 'user', parts }],
  });

  return res.candidates[0].content.parts[0].text.trim();
}

// ── POST /api/generate-animation ─────────────────────────────────────────
export function registerAnimationRoutes(app) {
  app.post('/api/generate-animation', async (req, res) => {
    const { drawings, story_details, story_id } = req.body;

    if (!drawings?.length) {
      return res.status(400).json({ error: 'No drawings provided.' });
    }

    const jobId = randomUUID();
    animationJobs[jobId] = {
      status: 'running',
      step: 'building_prompt',
      startTime: Date.now(),
      elapsed_ms: 0,
      veo_poll: 0,
      video_url: null,
      error: null,
    };

    // Run in background
    runAnimationPipeline(jobId, drawings, story_details, story_id).catch((e) => {
      animationJobs[jobId].status = 'error';
      animationJobs[jobId].error = e.message;
    });

    res.json({ job_id: jobId });
  });

  // ── GET /api/animation-progress/:job_id ────────────────────────────────
  app.get('/api/animation-progress/:jobId', (req, res) => {
    const job = animationJobs[req.params.jobId];
    if (!job) return res.status(404).json({ error: 'Job not found' });
    job.elapsed_ms = Date.now() - job.startTime;
    res.json(job);
  });
}

// ── The pipeline ──────────────────────────────────────────────────────────
async function runAnimationPipeline(jobId, drawings, storyDetails, storyId) {
  const job = animationJobs[jobId];

  // Step 1: Build prompt
  job.step = 'building_prompt';
  const veoPrompt = await buildVeoPrompt(drawings, storyDetails);
  console.log(`[Veo] prompt for job ${jobId}:\n${veoPrompt}`);

  // Step 2: Submit to Veo
  job.step = 'submitting_veo';
  let operation = await ai.models.generateVideos({
    model: 'veo-3.1-fast-generate-001',
    prompt: veoPrompt,
    config: { aspectRatio: '16:9', durationSeconds: 8 },
  });

  // Step 3: Poll until done
  job.step = 'polling_veo';
  const VEO_TIMEOUT = 8 * 60 * 1000;
  const start = Date.now();

  while (!operation.done) {
    if (Date.now() - start > VEO_TIMEOUT) throw new Error('Veo timed out after 8 minutes.');
    await new Promise((r) => setTimeout(r, 10_000));
    job.veo_poll++;
    operation = await ai.operations.getVideosOperation({ operation });
    console.log(`[Veo] poll #${job.veo_poll} for job ${jobId} — done: ${operation.done}`);
  }

  if (operation.error) throw new Error(`Veo error: ${JSON.stringify(operation.error)}`);
  if (!operation.response?.generatedVideos?.length) throw new Error('Veo returned no videos.');

  // Step 4: Download
  job.step = 'downloading';
  const filename = `animation_${storyId || jobId}_${Date.now()}.mp4`;
  const savePath = path.join(VIDEOS_DIR, filename);
  await ai.files.download({
    file: operation.response.generatedVideos[0].video,
    downloadPath: savePath,
  });

  job.video_url = `/api/scene-video/${filename}`;
  job.status = 'done';
  job.step = 'done';
  console.log(`[Veo] job ${jobId} done → ${job.video_url}`);
}
